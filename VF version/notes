async linkContentVersionToEmail({
    accessToken,
    instanceUrl,
    contentVersionId,
    emailId
}) {
    try {
        // STEP 1 — Query ContentDocumentId
        const query = `SELECT ContentDocumentId FROM ContentVersion WHERE Id='${contentVersionId}'`;
        const queryUrl = `${instanceUrl}/services/data/v60.0/query?q=${encodeURIComponent(query)}`;

        const queryResponse = await fetch(queryUrl, {
            method: 'GET',
            headers: {
                'Authorization': `Bearer ${accessToken}`
            }
        });

        if (!queryResponse.ok) {
            const err = await queryResponse.json();
            console.error('Query error:', err);
            throw new Error(JSON.stringify(err));
        }

        const queryResult = await queryResponse.json();

        if (!queryResult.records || queryResult.records.length === 0) {
            throw new Error('No ContentDocumentId found');
        }

        const contentDocumentId = queryResult.records[0].ContentDocumentId;
        console.log('ContentDocumentId:', contentDocumentId);

        // STEP 2 — Create ContentDocumentLink
        const linkUrl = `${instanceUrl}/services/data/v60.0/sobjects/ContentDocumentLink`;

        const body = {
            ContentDocumentId: contentDocumentId,
            LinkedEntityId: emailId,
            ShareType: 'V'
        };

        const linkResponse = await fetch(linkUrl, {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${accessToken}`,
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(body)
        });

        if (!linkResponse.ok) {
            const err = await linkResponse.json();
            console.error('Link error:', err);
            throw new Error(JSON.stringify(err));
        }

        const result = await linkResponse.json();
        console.log('File linked successfully:', result);

        return result;

    } catch (error) {
        console.error('Error in linking flow:', error);
        throw error;
    }
}



Architecture: Authorization Code Flow with Popup
plain
Copy
┌─────────────────────────────────────────────────────────────────────────┐
│                              USER BROWSER                               │
│  ┌─────────────────┐    ┌──────────────────────┐    ┌─────────────────┐ │
│  │  LWC            │───▶│  Popup VF Page       │───▶│  Salesforce     │
│  │  (Drag & Drop)  │    │  (OAuth Handler)     │    │  OAuth Endpoint │
│  │                 │    │                      │    │  (/authorize)   │
│  │  1. User drops  │    │  2. Redirects to     │    │                 │
│  │     email file  │    │     /authorize       │    │                 │
│  │                 │    │                      │    │                 │
│  │  5. Receives    │◄───│  4. Receives code    │◄───│  3. User logs   │
│  │     token       │    │     via redirect_uri │    │     in, approves│
│  │                 │    │                      │    │                 │
│  └─────────────────┘    └──────────────────────┘    └─────────────────┘
│         │                                              │
│         │                                              │
│         ▼                                              │
│  ┌─────────────────────────────────────────────────────────┐            │
│  │  LWC calls Salesforce REST API directly with token       │            │
│  │  POST /services/data/v66.0/sobjects/ContentVersion      │            │
│  │  Authorization: Bearer <token>                          │            │
│  └─────────────────────────────────────────────────────────┘            │
└─────────────────────────────────────────────────────────────────────────┘
